{
  "name": "simlauncher",
  "version": "1.0.0",
  "description": "SimLauncher - Multi app launcher for simracing",
  "main": "out/main/index.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Stashpeak/SimLauncher.git"
  },
  "bugs": {
    "url": "https://github.com/Stashpeak/SimLauncher/issues"
  },
  "homepage": "https://simlauncher.com/",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run",
    "build": "electron-vite build",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "lint": "eslint .",
    "preload:types": "node scripts/generate-preload-types.mjs",
    "preload:types:check": "node scripts/generate-preload-types.mjs --check",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "npm run typecheck:tsc && npm run preload:types:check",
    "typecheck:tsc": "tsc",
    "preview": "electron-vite preview",
    "prepare": "git config core.hooksPath .githooks"
  },
  "keywords": [
    "simracing",
    "launcher",
    "electron",
    "react",
    "typescript",
    "windows",
    "sim-racing"
  ],
  "author": "Stashpeak",
  "license": "GPL-3.0-only",
  "dependencies": {
    "@floating-ui/react": "^0.27.19",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.3.0",
    "react": "^19.2.6",
    "react-colorful": "^5.7.0",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.2",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.5"
  },
  "overrides": {
    "@electron/asar": "4.2.0",
    "js-yaml": "4.1.1",
    "esbuild": "^0.28.1"
  }
}
